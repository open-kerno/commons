# Logger
LOG_FORMAT=logfmt
LOG_LEVEL=debug
LOG_MAX_DEPTH=3
LOG_SILENT=false
LOG_MASK_SYMBOL=*

# PostgreSQL — replace POSTGRES with your configName in uppercase (e.g. wrapper('postgres'))
POSTGRES_HOST=localhost
POSTGRES_PORT=25432
POSTGRES_DBNAME=mydb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_MIN=20
POSTGRES_MAX=200
POSTGRES_IDLE_TIMEOUT=30000
POSTGRES_CONNECTION_TIMEOUT=5000
POSTGRES_STATEMENT_TIMEOUT=45000
